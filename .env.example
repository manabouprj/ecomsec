# EcomSec — Environment Variables Template
# ⚠️  NEVER commit a populated .env file to Git
# ⚠️  All values below are PLACEHOLDERS — replace with vault references
# Author: Alvin, Security Architect

# ─── PAPERCLIP ORCHESTRATION ──────────────────────────────────────
PAPERCLIP_ORCHESTRATOR_URL=http://paperclip:9000
PAPERCLIP_EVENT_BUS_URL=http://paperclip:9000/events
PAPERCLIP_BI_KEY=VAULT_REF:secret/ecomsec/paperclip/bi_key
PAPERCLIP_DEPLOY_TOKEN=VAULT_REF:secret/ecomsec/paperclip/deploy_token

# ─── DATABASE ─────────────────────────────────────────────────────
