# EcomSec .gitignore
# Author: Alvin, Security Architect

# ─── SECRETS — NEVER COMMIT ───────────────────────────────────────
.env
*.env
.env.local
.env.production
*.pem
*.key
*.p12
*.pfx
secrets/
vault/
credentials/

# ─── PYTHON ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ─── NODE / DASHBOARD ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/
build/
dist/

# ─── DOCKER ──────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── IDE / OS ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.log

# ─── GENERATED REPORTS ───────────────────────────────────────────
reports/generated/*
!reports/generated/.gitkeep

# ─── TERRAFORM STATE ─────────────────────────────────────────────
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
